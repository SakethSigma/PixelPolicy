OPENAI_API_KEY=your_openai_api_key

# Inference endpoint the agents hit (a local vLLM server, or hosted OpenAI).
# For local vLLM (see inference/), point at its OpenAI-compatible URL.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
INFERENCE_MODEL=Qwen/Qwen3.5-0.8B

# ── Distillation (see distillation/) ───────────────────────────────────────────
# Teacher model (Claude) used to generate gameplay trajectories. The Anthropic SDK
# reads ANTHROPIC_API_KEY automatically.
ANTHROPIC_API_KEY=your_anthropic_api_key
TEACHER_MODEL=claude-opus-4-8
# Where the combined SFT dataset is pushed. huggingface_hub reads HF_TOKEN for auth.
HF_HUB_REPO_ID=your-username/pixelpolicy-distill
# HF_TOKEN=your_hf_write_token
